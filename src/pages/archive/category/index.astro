---
// filepath: src/pages/archive/category/index.astro
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { i18n } from "@i18n/translation";
import I18nKey from "@i18n/i18nKey";
import Categories from "@components/widget/Categories.astro";
import { getEntry } from "astro:content";
import Markdown from "@components/misc/Markdown.astro";
import RollingCountCard from "@components/misc/RollingCountCard.astro";
import { getCategoryList } from "@utils/content-utils";

const title = i18n(I18nKey.categories);
// 加载 categories 内容文件
const categoriesPost = await getEntry("spec", "categories");
if (!categoriesPost) {
  throw new Error("Missing content entry: spec/categories");
}
const { Content } = await (categoriesPost as any).render();
const categoryList = await getCategoryList();
---

<MainGridLayout title={title} description={title}>
  <div
    class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32"
  >
    <div class="card-base z-10 px-9 py-6 relative w-full">
      <!-- 使用内容文件中的标题和描述，替换原来的 h1 标签 -->
      <Markdown class="mb-6">
        <Content />
      </Markdown>
      <RollingCountCard
        class="mb-6"
        label={title}
        value={categoryList.length}
        icon="material-symbols:category-rounded"
      />
      <Categories class="w-full" />
    </div>
  </div>
</MainGridLayout>
