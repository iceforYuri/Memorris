---
import ArchivePanel from "@components/ArchivePanel.astro";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSortedPosts, getCategoryList } from "@utils/content-utils";

export async function getStaticPaths() {
  const categories = await getCategoryList();

  // 为每个分类生成路径
  return categories.map((category) => ({
    params: {
      // URL 中使用编码后的分类名
      category: category.urlSafeName,
    },
    // 存储原始分类名，供页面组件使用
    props: {
      originalCategory: category.name,
    },
  }));
}

// 接收原始分类名
const { originalCategory } = Astro.props;
---

<MainGridLayout
  title={`${originalCategory} - ${i18n(I18nKey.categories)}`}
  description={`${i18n(I18nKey.categories)}: ${originalCategory}`}
>
  <ArchivePanel categories={[originalCategory]} />
</MainGridLayout>
