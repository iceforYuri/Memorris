---
// filepath: src/pages/archive/tag/[tag].astro
import ArchivePanel from "@components/ArchivePanel.astro";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSortedPosts } from "@utils/content-utils";
import Markdown from "@components/misc/Markdown.astro";

export async function getStaticPaths() {
  const posts = await getSortedPosts();

  // 收集所有标签
  const allTags = posts.reduce<Set<string>>((acc, post) => {
    post.data.tags.forEach((tag) => acc.add(tag));
    return acc;
  }, new Set());

  const allTagsArray = Array.from(allTags);

  // 为每个标签生成路径和编码后的参数
  return allTagsArray.map((tag) => ({
    params: {
      // URL 中使用编码后的标签名
      tag: encodeURIComponent(tag),
    },
    // 存储原始标签名，供页面组件使用
    props: {
      originalTag: tag,
    },
  }));
}

// 接收原始标签名
const { originalTag } = Astro.props;
---

<MainGridLayout
  title={`${originalTag} - ${i18n(I18nKey.tags)}`}
  description={`${i18n(I18nKey.tags)}: ${originalTag}`}
>
  <div
    class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32"
  >
    <div class="card-base z-10 px-9 py-6 relative w-full">
      <!-- 使用 Markdown 组件渲染标题 -->
      <Markdown class="mb-6">
        # {originalTag}
      </Markdown>

      <ArchivePanel tags={[originalTag]} />
    </div>
  </div>
</MainGridLayout>
