---
// filepath: f:\hexo\fuwari\fuwari\src\components\widget\TOC.astro
import type { MarkdownHeading } from 'astro';
import { siteConfig } from "../../config";

interface Props {
  class?: string
  headings: MarkdownHeading[]
}

let { headings = [] } = Astro.props;

let minDepth = 10;
for (const heading of headings) {
    minDepth = Math.min(minDepth, heading.depth);
}

const className = Astro.props.class

const removeTailingHash = (text: string) => {
    let lastIndexOfHash = text.lastIndexOf('#');
    if (lastIndexOfHash != text.length - 1) {
        return text;
    }

    return text.substring(0, lastIndexOfHash);
}

let heading1Count = 1;

const maxLevel = siteConfig.toc.depth;

// 对标题进行分组处理
const groupedHeadings = [];
let currentGroup = null;

headings.filter((heading) => heading.depth < minDepth + maxLevel).forEach((heading) => {
    if (heading.depth === minDepth) {
        // 大标题，创建新组
        currentGroup = {
            heading: heading,
            children: []
        };
        groupedHeadings.push(currentGroup);
    } else if (currentGroup) {
        // 子标题，添加到当前组
        currentGroup.children.push(heading);
    }
});
---

<!-- 添加内联样式以确保样式应用 -->
<style is:global>
:root {
  --toc-width: 14rem; /* 加宽目录栏 */
  --toc-indicator-color: #00BEE0; /* 追踪颜色 */
}

.toc-group {
  margin-bottom: 0.5rem;
}

.child-headings {
  max-height: 0;
  overflow: hidden;
  opacity: 0;
  transition: all 0.3s ease-in-out;
}

.toc-group.active .child-headings {
  max-height: 1000px;
  opacity: 1;
}

/* TOC 进度指示器样式 */
.left-toc-panel #active-indicator {
  background-color: rgba(0, 190, 224, 0.15) !important;
  border-color: var(--toc-indicator-color) !important;
  border-width: 2px !important;
  border-style: dashed !important;
  border-radius: 0.75rem !important;
  z-index: -1 !important;
}

/* 浅色模式下的进度指示器 */
:root:not(.dark) .left-toc-panel #active-indicator {
  background-color: rgba(0, 190, 224, 0.2) !important;
}

/* 深色模式下的进度指示器 */
:root.dark .left-toc-panel #active-indicator {
  background-color: rgba(0, 190, 224, 0.25) !important;
}

/* hover 时的样式 */
.left-toc-panel table-of-contents:hover #active-indicator {
  background-color: transparent !important;
  border-color: var(--toc-indicator-color) !important;
}
</style>

<div id="toc">
<table-of-contents class:list={[className, "group"]}>
    <!-- 使用分组渲染标题 -->
    {groupedHeadings.map((group, idx) => (
        <div class="toc-group" data-slug={group.heading.slug}>
            <!-- 大标题始终可见 -->
            <a href={`#${group.heading.slug}`} class="px-2 flex gap-2 relative transition w-full min-h-9 rounded-xl
                hover:bg-[var(--toc-btn-hover)] active:bg-[var(--toc-btn-active)] py-2 parent-heading"
            >
                <div class="transition w-5 h-5 shrink-0 rounded-lg text-xs flex items-center justify-center font-bold
                    bg-[var(--toc-badge-bg)] text-[var(--btn-content)]"
                >
                    {idx + 1}
                </div>
                <div class="transition text-sm text-50">{removeTailingHash(group.heading.text)}</div>
            </a>
            
            <!-- 子标题部分，初始隐藏 -->
<div class="child-headings">
    {group.children.map((childHeading) => (
        <a href={`#${childHeading.slug}`} class="px-2 flex gap-2 relative transition w-full min-h-8 rounded-xl
            hover:bg-[var(--toc-btn-hover)] active:bg-[var(--toc-btn-active)] py-1.5"
        >
            <div class:list={["transition w-5 h-5 shrink-0 rounded-lg text-xs flex items-center justify-center",
                {
                    "ml-4": childHeading.depth == minDepth + 1,
                    "ml-8": childHeading.depth == minDepth + 2,
                    "ml-12": childHeading.depth == minDepth + 3,
                    "ml-16": childHeading.depth == minDepth + 4,
                    "ml-20": childHeading.depth == minDepth + 5,
                    "m1-24": childHeading.depth == minDepth + 6,
                }
            ]}>
                {childHeading.depth == minDepth + 1 && <div class="transition w-2 h-2 rounded-[0.1875rem] bg-[var(--toc-badge-bg)]"></div>}
                {childHeading.depth == minDepth + 2 && <div class="transition w-1.5 h-1.5 rounded-sm bg-black/5 dark:bg-white/10"></div>}
                {childHeading.depth == minDepth + 3 && <div class="transition w-1.5 h-1.5 rounded-sm bg-black/5 dark:bg-white/10"></div>}
                {childHeading.depth == minDepth + 4 && <div class="transition w-1 h-1 rounded-sm bg-black/5 dark:bg-white/10"></div>}
                {childHeading.depth == minDepth + 5 && <div class="transition w-1 h-1 rounded-sm bg-black/5 dark:bg-white/10"></div>}
                {childHeading.depth == minDepth + 6 && <div class="transition w-1 h-1 rounded-sm bg-black/5 dark:bg-white/10"></div>}
            </div>
            <div class:list={["transition text-sm", {
                "text-50": childHeading.depth == minDepth + 1,
                "text-30": childHeading.depth == minDepth + 2,
                "text-30 opacity-80": childHeading.depth == minDepth + 3,
                "text-30 opacity-70": childHeading.depth == minDepth + 4,
                "text-30 opacity-60": childHeading.depth == minDepth + 5,
                "text-30 opacity-50": childHeading.depth == minDepth + 6,
            }]}>{removeTailingHash(childHeading.text)}</div>
        </a>
    ))}
</div>
        </div>
    ))}
    <div id="active-indicator" class:list={[{'hidden': headings.length == 0}, "-z-10 absolute left-0 right-0 transition-all pointer-events-none"]}></div>
</table-of-contents>
</div>


<script>
class TableOfContents extends HTMLElement {
    tocEl: HTMLElement | null = null;
    visibleClass = "visible";
    observer: IntersectionObserver;
    anchorNavTarget: HTMLElement | null = null;
    headingIdxMap = new Map<string, number>();
    headings: HTMLElement[] = [];
    sections: HTMLElement[] = [];
    tocEntries: HTMLAnchorElement[] = [];
    active: boolean[] = [];
    activeIndicator: HTMLElement | null = null;
    // 跟踪目录组
    tocGroups: HTMLDivElement[] = [];
    activeGroup: HTMLDivElement | null = null;

    constructor() {
        super();
        this.observer = new IntersectionObserver(
            this.markVisibleSection, { threshold: 0.1 } // 增加阈值以更好地检测
        );
    };

    markVisibleSection = (entries: IntersectionObserverEntry[]) => {
        entries.forEach((entry) => {
            const id = entry.target.children[0]?.getAttribute("id");
            const idx = id ? this.headingIdxMap.get(id) : undefined;
            if (idx != undefined) {
                this.active[idx] = entry.isIntersecting;
            }

            // 检查是否为大标题，控制子标题的显示/隐藏
            if (entry.isIntersecting) {
                this.toggleSubHeadings(id);
            }

            if (entry.isIntersecting && this.anchorNavTarget == entry.target.firstChild)
                this.anchorNavTarget = null;
        });

        if (!this.active.includes(true))
            this.fallback();
        this.update();
    };

    // 控制子标题显示/隐藏 - 根据当前可见的标题ID找到对应的组
    toggleSubHeadings = (id: string | undefined | null) => {
        if (!id) return;
        
        // 首先尝试直接匹配一级标题
        let group = this.tocGroups.find(g => g.dataset.slug === id);
        
        // 如果没找到，说明是子标题，需要找到包含这个子标题链接的组
        if (!group) {
            for (const g of this.tocGroups) {
                const childLink = g.querySelector(`a[href="#${id}"]`);
                if (childLink) {
                    group = g;
                    break;
                }
            }
        }
        
        if (!group) return;

        // 如果这个组已经激活，不需要再做任何事
        if (this.activeGroup === group) return;
        
        // 移除之前激活组的active类
        if (this.activeGroup) {
            this.activeGroup.classList.remove('active');
        }
        
        // 激活当前组
        group.classList.add('active');
        this.activeGroup = group;
    };

    toggleActiveHeading = () => {
        let i = this.active.length - 1;
        let min = this.active.length - 1, max = 0;
        while (i >= 0 && !this.active[i]) {
            this.tocEntries[i].classList.remove(this.visibleClass);
            i--;
        }
        while (i >= 0 && this.active[i]) {
            this.tocEntries[i].classList.add(this.visibleClass);
            min = Math.min(min, i);
            max = Math.max(max, i);
            i--;
        }
        while (i >= 0) {
            this.tocEntries[i].classList.remove(this.visibleClass);
            i--;
        }
        let parentOffset = this.tocEl?.getBoundingClientRect().top || 0;
        let scrollOffset = this.tocEl?.scrollTop || 0;
        let top = this.tocEntries[min].getBoundingClientRect().top - parentOffset + scrollOffset;
        let bottom = this.tocEntries[max].getBoundingClientRect().bottom - parentOffset + scrollOffset;
        this.activeIndicator?.setAttribute("style", `top: ${top}px; height: ${bottom - top}px`);
    };

    scrollToActiveHeading = () => {
        if (this.anchorNavTarget || !this.tocEl) return;
        const activeHeading =
            document.querySelectorAll<HTMLDivElement>(`#toc .${this.visibleClass}`);
        if (!activeHeading.length) return;

        const topmost = activeHeading[0];
        const bottommost = activeHeading[activeHeading.length - 1];
        const tocHeight = this.tocEl.clientHeight;

        let top;
        if (bottommost.getBoundingClientRect().bottom -
            topmost.getBoundingClientRect().top < 0.9 * tocHeight)
            top = topmost.offsetTop - 32;
        else
            top = bottommost.offsetTop - tocHeight * 0.8;

        this.tocEl.scrollTo({
            top,
            left: 0,
            behavior: "smooth",
        });
    };

    update = () => {
        requestAnimationFrame(() => {
            this.toggleActiveHeading();
            this.scrollToActiveHeading();
        });
    };

    fallback = () => {
        if (!this.sections.length) return;

        for (let i = 0; i < this.sections.length; i++) {
            let offsetTop = this.sections[i].getBoundingClientRect().top;
            let offsetBottom = this.sections[i].getBoundingClientRect().bottom;

            if (this.isInRange(offsetTop, 0, window.innerHeight)
                || this.isInRange(offsetBottom, 0, window.innerHeight)
                || (offsetTop < 0 && offsetBottom > window.innerHeight)) {                    
                this.markActiveHeading(i);
            }
            else if (offsetTop > window.innerHeight) break;
        }
    };

    markActiveHeading = (idx: number)=> {
        this.active[idx] = true;
    };

    handleAnchorClick = (event: Event) => {
        const anchor = event
            .composedPath()
            .find((element) => element instanceof HTMLAnchorElement);

        if (anchor) {
            const id = decodeURIComponent(anchor.hash?.substring(1));
            const idx = this.headingIdxMap.get(id);
            if (idx !== undefined) {
                this.anchorNavTarget = this.headings[idx];
                
                // 点击时也展开对应的子标题
                this.toggleSubHeadings(id);
            } else {
                this.anchorNavTarget = null;
            }
        }
    };

    isInRange(value: number, min: number, max: number) {
        return min < value && value < max;
    };

    connectedCallback() {
        // 等待动画结束，以确保获得正确的位置
        const element = document.querySelector('.prose');
        if (element) {
            // 检查动画是否已经完成
            const computedStyle = getComputedStyle(element);
            const animationName = computedStyle.animationName;
            
            if (animationName && animationName !== 'none') {
                element.addEventListener('animationend', () => {
                    this.init();
                }, { once: true });
            } else {
                // 动画已完成或没有动画，直接初始化
                this.init();
            }
        } else {
            // 如果没有找到元素，延迟初始化
            setTimeout(() => this.init(), 300);
        }
    };

    init() {
        // 先清理旧状态
        this.cleanup();
        
        this.tocEl = document.getElementById("toc-inner-wrapper");

        if (!this.tocEl) return;

        this.tocEl.addEventListener("click", this.handleAnchorClick, {
            capture: true,
        });

        this.activeIndicator = document.getElementById("active-indicator");
        
        // 获取所有目录组
        this.tocGroups = Array.from(
            document.querySelectorAll<HTMLDivElement>("#toc .toc-group")
        );

        this.tocEntries = Array.from(
            document.querySelectorAll<HTMLAnchorElement>("#toc a[href^='#']")
        );

        if (this.tocEntries.length === 0) return;

        this.sections = new Array(this.tocEntries.length);
        this.headings = new Array(this.tocEntries.length);
        for (let i = 0; i < this.tocEntries.length; i++) {
            const id = decodeURIComponent(this.tocEntries[i].hash?.substring(1));
            const heading = document.getElementById(id);
            const section = heading?.parentElement;
            if (heading instanceof HTMLElement && section instanceof HTMLElement) {
                this.headings[i] = heading;
                this.sections[i] = section;
                this.headingIdxMap.set(id, i);
            }
        }
        this.active = new Array(this.tocEntries.length).fill(false);

        this.sections.forEach((section) =>
            this.observer.observe(section)
        );

        this.fallback();
        this.update();
        
        // 初始化时展开第一个可见的目录组
        this.initActiveGroup();
    };
    
    // 初始化时根据当前滚动位置展开对应的目录组
    initActiveGroup = () => {
        // 找到第一个活动的标题
        const firstActiveIdx = this.active.findIndex(a => a);
        if (firstActiveIdx >= 0 && this.tocEntries[firstActiveIdx]) {
            const id = decodeURIComponent(this.tocEntries[firstActiveIdx].hash?.substring(1));
            this.toggleSubHeadings(id);
        } else if (this.tocGroups.length > 0) {
            // 如果没有活动标题，默认展开第一组
            this.tocGroups[0].classList.add('active');
            this.activeGroup = this.tocGroups[0];
        }
    };
    
    // 清理旧状态
    cleanup = () => {
        // 停止观察旧的 sections
        this.sections.forEach((section) => {
            if (section) this.observer.unobserve(section);
        });
        
        // 移除旧的事件监听器
        this.tocEl?.removeEventListener("click", this.handleAnchorClick);
        
        // 重置状态
        this.headingIdxMap.clear();
        this.headings = [];
        this.sections = [];
        this.tocEntries = [];
        this.active = [];
        this.tocGroups = [];
        this.activeGroup = null;
        this.anchorNavTarget = null;
    };

    disconnectedCallback() {
        this.cleanup();
        this.observer.disconnect();
    };
}

customElements.define("table-of-contents", TableOfContents);
</script>